{
  "name": "vscode-tingly-translate",
  "displayName": "tingly-translate",
  "description": "vscode-tingly-translate",
  "version": "0.0.1",
  "author": {
    "name": "Tingly"
  },
  "repository": {
    "url": "https://github.com/FFengIll/vscode-tingly-translate"
  },
  "publisher": "tingly-dev",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage",
    "onCommand:vscode-tingly-translate.translateSelection",
    "onCommand:vscode-tingly-translate.clearInlineTranslations",
    "onCommand:vscode-tingly-translate.translateSelectionReplace",
    "onCommand:vscode-tingly-translate.translateSelectionInsertBelow",
    "onCommand:vscode-tingly-translate.translateSelectionCopy"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-tingly-translate.translateSelection",
        "title": "Tingly Translate: Translate Selection",
        "icon": "$(globe)"
      },
      {
        "command": "vscode-tingly-translate.clearInlineTranslations",
        "title": "Tingly Translate: Clear Inline Translations"
      },
      {
        "command": "vscode-tingly-translate.translateSelectionReplace",
        "title": "Tingly Translate: Replace Selection with Translation"
      },
      {
        "command": "vscode-tingly-translate.translateSelectionInsertBelow",
        "title": "Tingly Translate: Insert Translation Below"
      },
      {
        "command": "vscode-tingly-translate.translateSelectionCopy",
        "title": "Tingly Translate: Copy Translation"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vscode-tingly-translate.translateSelection",
          "when": "editorTextFocus && editorHasSelection",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "vscode-tingly-translate.translateSelection",
          "when": "editorHasSelection",
          "group": "9_cutcopypaste"
        },
        {
          "command": "vscode-tingly-translate.clearInlineTranslations",
          "group": "9_cutcopypaste"
        },
        {
          "command": "vscode-tingly-translate.translateSelectionReplace",
          "when": "editorHasSelection",
          "group": "9_cutcopypaste"
        },
        {
          "command": "vscode-tingly-translate.translateSelectionInsertBelow",
          "when": "editorHasSelection",
          "group": "9_cutcopypaste"
        },
        {
          "command": "vscode-tingly-translate.translateSelectionCopy",
          "when": "editorHasSelection",
          "group": "9_cutcopypaste"
        }
      ]
    },
    "keybindings": [
      {
        "command": "vscode-tingly-translate.translateSelection",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "vscode-tingly-translate.clearInlineTranslations",
        "key": "ctrl+alt+shift+t",
        "mac": "cmd+alt+shift+t",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Tingly Translate",
      "properties": {
        "tinglyTranslate.provider": {
          "type": "string",
          "enum": [
            "googleFree",
            "microsoftFree",
            "googleCloud",
            "microsoftAzure",
            "libreTranslate",
            "deepl",
            "myMemory",
            "lingva",
            "apertium",
            "baidu",
            "youdao",
            "openai",
            "anthropic"
          ],
          "default": "googleFree",
          "description": "Translation provider used by Tingly Translate."
        },
        "tinglyTranslate.sourceLanguage": {
          "type": "string",
          "default": "auto",
          "description": "Source language. Use auto to let the provider detect it."
        },
        "tinglyTranslate.targetLanguage": {
          "type": "string",
          "default": "zh-CN",
          "description": "Target language, such as zh-CN, en, ja, or fr."
        },
        "tinglyTranslate.outputMode": {
          "type": "string",
          "enum": [
            "inline",
            "replace",
            "insertBelow",
            "copy",
            "showOnly"
          ],
          "default": "inline",
          "description": "Default output behavior for Translate Selection."
        },
        "tinglyTranslate.inlineMaxChars": {
          "type": "number",
          "default": 120,
          "minimum": 20,
          "maximum": 500,
          "description": "Maximum characters shown in the inline translation decoration before truncating. Hover shows the full translation."
        },
        "tinglyTranslate.providers.googleCloud.apiKey": {
          "type": "string",
          "default": "",
          "description": "Google Cloud Translation API key."
        },
        "tinglyTranslate.providers.googleCloud.endpoint": {
          "type": "string",
          "default": "",
          "description": "Optional Google Cloud Translation endpoint override."
        },
        "tinglyTranslate.providers.microsoftAzure.apiKey": {
          "type": "string",
          "default": "",
          "description": "Microsoft Azure Translator API key."
        },
        "tinglyTranslate.providers.microsoftAzure.endpoint": {
          "type": "string",
          "default": "",
          "description": "Optional Microsoft Azure Translator endpoint override."
        },
        "tinglyTranslate.providers.microsoftAzure.region": {
          "type": "string",
          "default": "",
          "description": "Microsoft Translator region, such as eastus. Required for many Azure Translator resources."
        },
        "tinglyTranslate.providers.libreTranslate.endpoint": {
          "type": "string",
          "default": "",
          "description": "LibreTranslate endpoint. Defaults to https://libretranslate.com/translate."
        },
        "tinglyTranslate.providers.libreTranslate.apiKey": {
          "type": "string",
          "default": "",
          "description": "Optional LibreTranslate API key."
        },
        "tinglyTranslate.providers.deepl.apiKey": {
          "type": "string",
          "default": "",
          "description": "DeepL API key."
        },
        "tinglyTranslate.providers.deepl.endpoint": {
          "type": "string",
          "default": "",
          "description": "DeepL endpoint. Defaults to the DeepL Free API endpoint."
        },
        "tinglyTranslate.providers.myMemory.endpoint": {
          "type": "string",
          "default": "",
          "description": "MyMemory endpoint. Defaults to https://api.mymemory.translated.net/get."
        },
        "tinglyTranslate.providers.myMemory.apiKey": {
          "type": "string",
          "default": "",
          "description": "Optional MyMemory API key."
        },
        "tinglyTranslate.providers.myMemory.email": {
          "type": "string",
          "default": "",
          "description": "Optional MyMemory contact email."
        },
        "tinglyTranslate.providers.lingva.endpoint": {
          "type": "string",
          "default": "https://lingva.ml",
          "description": "Lingva Translate instance base URL."
        },
        "tinglyTranslate.providers.apertium.endpoint": {
          "type": "string",
          "default": "https://apertium.org/apy",
          "description": "Apertium APY base URL."
        },
        "tinglyTranslate.providers.baidu.appId": {
          "type": "string",
          "default": "",
          "description": "Baidu Translate app ID."
        },
        "tinglyTranslate.providers.baidu.apiKey": {
          "type": "string",
          "default": "",
          "description": "Baidu Translate secret key."
        },
        "tinglyTranslate.providers.baidu.endpoint": {
          "type": "string",
          "default": "https://fanyi-api.baidu.com/api/trans/vip/translate",
          "description": "Baidu Translate API endpoint."
        },
        "tinglyTranslate.providers.youdao.appKey": {
          "type": "string",
          "default": "",
          "description": "Youdao Translate app key."
        },
        "tinglyTranslate.providers.youdao.apiSecret": {
          "type": "string",
          "default": "",
          "description": "Youdao Translate app secret."
        },
        "tinglyTranslate.providers.youdao.endpoint": {
          "type": "string",
          "default": "https://openapi.youdao.com/api",
          "description": "Youdao Translate API endpoint."
        },
        "tinglyTranslate.providers.youdao.vocabId": {
          "type": "string",
          "default": "",
          "description": "Optional Youdao vocabulary ID."
        },
        "tinglyTranslate.providers.openai.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "OpenAI-compatible API base URL."
        },
        "tinglyTranslate.providers.openai.endpoint": {
          "type": "string",
          "default": "",
          "description": "Optional full OpenAI-compatible chat completions endpoint. Overrides baseUrl when set."
        },
        "tinglyTranslate.providers.openai.apiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI-compatible API key."
        },
        "tinglyTranslate.providers.openai.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "OpenAI-compatible model name."
        },
        "tinglyTranslate.providers.openai.prompt": {
          "type": "string",
          "default": "Translate the following text from {sourceLanguage} to {targetLanguage}. Return only the translation, without explanations or quotes.\n\n{text}",
          "description": "Prompt template for OpenAI-compatible translation. Supports {text}, {sourceLanguage}, and {targetLanguage}."
        },
        "tinglyTranslate.providers.openai.maxTokens": {
          "type": "number",
          "default": 2000,
          "minimum": 1,
          "description": "Maximum output tokens for OpenAI-compatible translation."
        },
        "tinglyTranslate.providers.openai.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature for OpenAI-compatible translation."
        },
        "tinglyTranslate.providers.anthropic.baseUrl": {
          "type": "string",
          "default": "https://api.anthropic.com/v1",
          "description": "Anthropic API base URL."
        },
        "tinglyTranslate.providers.anthropic.endpoint": {
          "type": "string",
          "default": "",
          "description": "Optional full Anthropic messages endpoint. Overrides baseUrl when set."
        },
        "tinglyTranslate.providers.anthropic.apiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key."
        },
        "tinglyTranslate.providers.anthropic.model": {
          "type": "string",
          "default": "claude-3-5-haiku-latest",
          "description": "Anthropic model name."
        },
        "tinglyTranslate.providers.anthropic.prompt": {
          "type": "string",
          "default": "Translate the following text from {sourceLanguage} to {targetLanguage}. Return only the translation, without explanations or quotes.\n\n{text}",
          "description": "Prompt template for Anthropic translation. Supports {text}, {sourceLanguage}, and {targetLanguage}."
        },
        "tinglyTranslate.providers.anthropic.maxTokens": {
          "type": "number",
          "default": 2000,
          "minimum": 1,
          "description": "Maximum output tokens for Anthropic translation."
        },
        "tinglyTranslate.providers.anthropic.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 1,
          "description": "Sampling temperature for Anthropic translation."
        },
        "tinglyTranslate.providers.anthropic.version": {
          "type": "string",
          "default": "2023-06-01",
          "description": "Anthropic API version header."
        },
        "tinglyTranslate.timeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "description": "Request timeout in milliseconds."
        },
        "tinglyTranslate.proxy.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable HTTP proxy for translation requests."
        },
        "tinglyTranslate.proxy.url": {
          "type": "string",
          "default": "",
          "description": "HTTP proxy URL, for example http://127.0.0.1:7890. HTTPS translation endpoints are tunneled through CONNECT."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
